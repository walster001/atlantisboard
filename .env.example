# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Local Docker dev persistence (docker-compose.yml bind mounts)
# Data is stored on disk under .docker-data/ by default — survives container removal.
# Use an absolute path to keep data outside the repo clone. See docs/DOCKER-DEV-DATA.md
# KANBOARD_DOCKER_DATA_DIR=./.docker-data

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/kanboard?replicaSet=rs0
MONGODB_DB_NAME=kanboard
# Production Docker Compose only (SCRAM auth + init). Local dev Compose stays unauthenticated.
# MONGODB_ROOT_USER=kanboard_root
# MONGODB_ROOT_PASSWORD=
# MONGODB_APP_USER=kanboard_app
# MONGODB_APP_PASSWORD=
# Production example URI (Compose service hostname `mongodb`):
# MONGODB_URI=mongodb://kanboard_app:APP_PASSWORD@mongodb:27017/kanboard?authSource=kanboard&replicaSet=rs0
# Change Streams ($changeStream) require a replica set. Off by default in non-production; in production they run unless disabled.
# ENABLE_CHANGE_STREAMS=true  — force on (e.g. dev against Atlas)
# ENABLE_CHANGE_STREAMS=false — force off
# DISABLE_CHANGE_STREAMS=true — always off
ENABLE_CHANGE_STREAMS=true
DISABLE_CHANGE_STREAMS=

# Redis (required at runtime)
# Used for: (1) express-session store (connect-redis + node-redis v5), (2) API rate limit counters (ioredis).
# Start Redis locally, or use Docker: `docker compose up -d redis` (see docker-compose.yml).
# In Compose, the app service uses REDIS_HOST=redis unless you override it.
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional. When set, must match Redis `requirepass` (see docker-compose.yml / docker-compose.prod.yml).
# Leave empty only for trusted local dev; use a strong secret in production.
REDIS_PASSWORD=
# Optional Redis ACL username (Redis 6+). Used with REDIS_PASSWORD for AUTH username password.
REDIS_USERNAME=
# TLS for both ioredis (rate limits) and node-redis (sessions). Typical managed Redis: REDIS_TLS=true, port 6380 or provider default.
REDIS_TLS=false
# Verify server certificate (default true). Set false only for local/dev with self-signed TLS (not for production).
REDIS_TLS_REJECT_UNAUTHORIZED=true
# PEM CA bundle file path for private CAs (optional; also see Node NODE_EXTRA_CA_CERTS).
REDIS_TLS_CA_PATH=
# Redis Cluster: horizontal scaling. When true, clients use Redis Cluster protocol (slot discovery, MOVED/ASK).
# List at least one reachable node; more is better for discovery. If REDIS_CLUSTER_NODES is empty, REDIS_HOST:REDIS_PORT is used.
REDIS_CLUSTER=false
# Example: redis-1.example.com:6379,redis-2.example.com:6379,[2001:db8::1]:6379
REDIS_CLUSTER_NODES=
# When cluster=true, route read-only commands to replicas where supported (sessions/rate limits still use masters for writes).
REDIS_CLUSTER_USE_REPLICAS=false
# Not implemented: REDIS_URL single string, Sentinel, non-TLS Stunnel-only. Sessions use key prefix `session:` (src/server/middleware/session.ts).

# JWT Configuration
# Generate: openssl rand -base64 48
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1h

# Session Configuration
# Generate: openssl rand -base64 48
SESSION_SECRET=your-session-secret-change-in-production

# CSRF token signing secret (required in production)
# Generate: openssl rand -base64 48
CSRF_SECRET=change-this-csrf-secret-in-production

# AES-256-GCM encryption for stored credentials (Admin OAuth secrets, etc.)
# Generate: openssl rand -base64 48
ENCRYPTION_KEY=change-this-to-a-secure-random-string-in-production

# HMAC signing for time-limited branding/font/asset URLs (required in production; must differ from JWT_SECRET)
# Generate: openssl rand -base64 48
MEDIA_SIGN_SECRET=change-this-media-sign-secret-in-production

# Google OAuth Configuration (optional; Admin Configuration → Login options can store client ID/secret instead)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google redirect URI. Google Cloud does not allow private IP redirect URIs; use a local hostname
# (e.g. kanboard.local in /etc/hosts → your machine) and set GOOGLE_OAUTH_BROWSER_ORIGIN to match.
# GOOGLE_CALLBACK_URL can stay a relative path (/api/v1/auth/google/callback); the server will
# send redirect_uri as GOOGLE_OAUTH_BROWSER_ORIGIN + that path. Open the app at that origin for
# Google sign-in. Optional: leave GOOGLE_OAUTH_BROWSER_ORIGIN empty and use a relative path only
# when every client host is already acceptable to Google (e.g. public HTTPS).
GOOGLE_CALLBACK_URL=/api/v1/auth/google/callback
# e.g. http://kanboard.local:3000 — must match an authorized redirect URI origin in Google Cloud.
GOOGLE_OAUTH_BROWSER_ORIGIN=
# When signing in via Google with a private LAN host (e.g. 192.168.x.x), Google requires
# device_id and device_name on the authorization request. Optional: defaults use the host
# and OS hostname when unset.
GOOGLE_OAUTH_DEVICE_ID=
GOOGLE_OAUTH_DEVICE_NAME=

# External MySQL (optional legacy env hints; Google + database verification uses Admin Configuration → Login options
# for host, database, user, password, and verification SQL — executed server-side with Bun SQL.)
EXTERNAL_MYSQL_HOST=
EXTERNAL_MYSQL_PORT=3306
EXTERNAL_MYSQL_DATABASE=
EXTERNAL_MYSQL_USERNAME=
EXTERNAL_MYSQL_PASSWORD=
EXTERNAL_MYSQL_ENABLED=false
# Comma-separated allowlist for MySQL import host (optional). When unset, private/metadata IPs are blocked via DNS resolution.
# MYSQL_ALLOWED_HOSTS=db.example.com,legacy.mysql.internal

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Optional: MinIO daemon root credentials (production Compose). When unset, MINIO_ACCESS_KEY/SECRET are used for the server.
# Set MINIO_ROOT_* to the root user and use distinct MINIO_ACCESS_KEY/SECRET for a scoped application user (see docs/wiki/environment-variables.md).
# MINIO_ROOT_ACCESS_KEY=
# MINIO_ROOT_SECRET_KEY=
# Multipart upload part size (MiB, 16–256). Larger = fewer MinIO round-trips for big attachments.
MINIO_UPLOAD_PART_SIZE_MB=128

# CORS Configuration
# Comma-separated allowed origins (example:
# CORS_ORIGIN=http://localhost:3000,http://192.168.1.42:36521)
# Production example: CORS_ORIGIN=https://app.atlantis.social
# Wildcard (*) is rejected when NODE_ENV=production.
# In development, localhost + private LAN origins are auto-allowed when this is empty.
# Production: requests without an Origin header are denied unless you set:
# CORS_ALLOW_MISSING_ORIGIN=true
CORS_ORIGIN=http://localhost:3000

# Development-only: skip SMTP TLS cert verification for local mail sinks (ignored in production).
# SMTP_TLS_INSECURE=true

# Reverse proxy (production)
# Number of trusted proxy hops between the client and this app (nginx/Caddy = 1).
TRUST_PROXY_HOPS=1

# Rate Limiting
RATE_LIMIT_AUTH_ATTEMPTS=900
RATE_LIMIT_AUTH_WINDOW=1
RATE_LIMIT_FILE_UPLOADS=10
RATE_LIMIT_FILE_UPLOAD_WINDOW=1
RATE_LIMIT_GENERAL_API=1000
RATE_LIMIT_GENERAL_API_WINDOW=1

# Upload limits (server). Multer, service validation, and the SPA UI share these caps.
# Card attachments: default 50 MB, clamped 1–1024. Prefer CARD_ATTACHMENT_MAX_MB.
CARD_ATTACHMENT_MAX_MB=50
# Legacy byte cap (used when CARD_ATTACHMENT_MAX_MB is unset), e.g. 1048576000 for 1000 MiB.
# MAX_FILE_SIZE=1048576000
# Board import JSON/CSV uploads: default 35 MB, clamped 5–250.
BOARD_IMPORT_MAX_MB=35

# Logging
LOG_LEVEL=info

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1

# Malware scanning (Pompelmi / ClamAV). Local dev: skip when clamd is not installed.
# Production: set POMPELMI_SKIP_SCAN=false (or remove) and run clamd; set host/port below.
POMPELMI_SKIP_SCAN=true
# POMPELMI_CLAMD_HOST=127.0.0.1
# POMPELMI_CLAMD_PORT=3310
# POMPELMI_FAIL_OPEN=false
# Scan timeout for large files (ms). ClamAV StreamMaxLength must be >= max upload size.
# POMPELMI_SCAN_TIMEOUT_MS=600000

# Local filesystem path on the server host where full backups (ZIP archives) are written.
# Must be an absolute path. Required for admin “Create Backup” and scheduled backups.
BACKUP_LOCATION=
