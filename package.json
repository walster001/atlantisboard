{
  "name": "kanboard",
  "version": "1.0.1",
  "description": "Fully-functional, self-hosted Kanban board application",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --watch src/server/index.ts",
    "dev:client": "bun run --watch src/client/index.tsx",
    "dev:worker": "bun run --watch src/server/workers/index.ts",
    "dev-start": "./scripts/dev-start.sh",
    "dev-deploy": "./scripts/dev-deploy.sh",
    "build:emoji-sheet": "bun run scripts/build-extended-emoji-spritesheet.ts",
    "build:client": "bun run scripts/build-client-with-css.ts",
    "build:client:watch": "bun run scripts/build-client-watch.ts",
    "build": "bun build src/server/index.ts --outdir dist/server --target bun --packages=external && bun build src/client/index.tsx --outdir dist/client --target browser --define process.env.NODE_ENV=\\\"production\\\" --external mongoose --external ioredis --external mongodb --external minio --external express --external socket.io --external passport && bun build src/server/workers/index.ts --outdir dist/workers --target bun --packages=external",
    "build:analyze": "bun build src/client/index.tsx --outdir dist/client --target browser --analyze",
    "start": "bun run dist/server/index.js",
    "start:worker": "bun run dist/workers/index.js",
    "test": "bun test",
    "test:installer": "bun test tests/installerLib.test.ts && bash packages/atlantisboard/install/test-idempotent-repair.sh",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit -p tsconfig.typecheck.json",
    "check:src-line-counts": "./scripts/check-src-line-counts.sh",
    "release:bundle": "./scripts/release-bundle.sh",
    "build:npm-package": "./scripts/build-npm-package.sh",
    "db:drop-activity-legacy-indexes": "bun run scripts/drop-activity-legacy-indexes.ts"
  },
  "keywords": [
    "kanban",
    "board",
    "trello",
    "wekan",
    "collaboration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.8.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "1.1.0",
    "@emoji-mart/data": "1.2.1",
    "@emoji-mart/react": "1.1.1",
    "@mantine/charts": "8.3.0",
    "@mantine/core": "8.3.0",
    "@mantine/dates": "8.3.0",
    "@mantine/dropzone": "^8.3.12",
    "@mantine/hooks": "8.3.0",
    "@mantine/modals": "8.3.0",
    "@mantine/notifications": "8.3.0",
    "@tabler/icons-react": "^3.36.1",
    "@tiptap/core": "3.20.4",
    "@tiptap/extension-character-count": "3.20.4",
    "@tiptap/extension-code-block-lowlight": "3.20.4",
    "@tiptap/extension-color": "3.20.4",
