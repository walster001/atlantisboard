    "socket.io-client": "4.8.3",
    "swiper": "12.1.4",
    "tailwindcss": "4.1.18",
    "tiptap-extension-resize-image": "1.3.3",
    "twemoji": "14.0.2",
    "unzipper": "^0.12.3",
    "web-push": "^3.6.7",
    "ws": "8.21.0",
