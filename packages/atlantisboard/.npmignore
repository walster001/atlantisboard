# Unbundled source and tests (publish only dist/, public/, install/)
src/
scripts/
tests/
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.test.js
**/*.spec.ts
**/*.spec.tsx
coverage/
.nyc_output/

# Dependencies (installed on host: bun install --production)
node_modules/
bun.lockb

# Build outputs not shipped
build/
release/
*.tsbuildinfo

# Environment and secrets
.env
.env.local
.env.*.local

# Logs and temporary files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
tmp/
temp/
*.tmp
.kombai/
wsl/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE and editor
.vscode/
.idea/
.cursor/
*.swp
*.swo
*.swn

# Repository layout (not runtime package contents)
.github/
docs/
pages/
specifications.md
Buglist-New.txt
docker-compose.yml
docker-compose.override.yml
.docker-data/
minio-data/
mongo-data/
redis-data/

# Dev tooling (TypeScript, lint, format — not needed on install host)
eslint.config.*
tsconfig*.json
postcss.config.*
prettier.config.*
.editorconfig

# Local-only security notes
docs/security/
