#!/usr/bin/env bash
# Run the Whiptail installer from an extracted release zip (Linux).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export ATLANTISBOARD_PACKAGE_ROOT="$ROOT"

usage() {
  cat <<'EOF'
Usage: atlantisboard-setup [options]

Interactive installer (default). For automated upgrade/repair on an existing install:

  sudo ./atlantisboard-setup --non-interactive --action update --install-dir /opt/atlantisboard

Options:
  --non-interactive, -y   Headless repair/update (requires existing install + .env)
  --action ACTION         update | repair  (default: update when non-interactive)
  --install-dir PATH      Target install directory (default: /opt/atlantisboard)
  -h, --help              Show this help

Environment:
  ATL_NONINTERACTIVE=1    Same as --non-interactive
  INSTALL_ACTION          Same as --action
  ATLANTISBOARD_INSTALL_DIR  Same as --install-dir
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --non-interactive | -y)
      export ATL_NONINTERACTIVE=1
      shift
      ;;
    --action)
      if [[ $# -lt 2 ]]; then
        echo "atlantisboard-setup: --action requires a value" >&2
        exit 1
      fi
      export INSTALL_ACTION="$2"
      shift 2
      ;;
    --install-dir)
      if [[ $# -lt 2 ]]; then
        echo "atlantisboard-setup: --install-dir requires a path" >&2
        exit 1
      fi
      export ATLANTISBOARD_INSTALL_DIR="$2"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "atlantisboard-setup: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

exec bash "${ROOT}/install/setup.sh"
