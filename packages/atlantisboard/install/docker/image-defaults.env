# Default container images for atlantisboard-setup Docker stacks.
# Quay.io MinIO manifests often time out on cloud VMs; Docker Hub mirrors the same RELEASE tags.
# Override in your install .env (e.g. /opt/atlantisboard/.env) for private registries.
#
# mongo:8.0 (floating) resolves to >=8.0.5, which refuses Linux kernel 6.19+ (SERVER-121912).
# Pin 8.0.4 until MongoDB ships a fixed 8.0.x; see install/docker/docker-compose.fullstack.yml.
ATLANTISBOARD_MONGO_IMAGE=docker.io/library/mongo:8.0.4
ATLANTISBOARD_MINIO_IMAGE=docker.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
ATLANTISBOARD_MINIO_MC_IMAGE=docker.io/minio/mc:RELEASE.2025-08-13T08-35-41Z
# Tag for mc CLI baked into the app image (GitHub releases; dl.min.io no longer hosts mc).
ATLANTISBOARD_MC_RELEASE=RELEASE.2025-08-13T08-35-41Z
