{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::import-inline",
        "arn:aws:s3:::card-attachments",
        "arn:aws:s3:::branding",
        "arn:aws:s3:::fonts",
        "arn:aws:s3:::user-avatars",
        "arn:aws:s3:::backgrounds",
        "arn:aws:s3:::backups"
      ]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::import-inline/*",
        "arn:aws:s3:::card-attachments/*",
        "arn:aws:s3:::branding/*",
        "arn:aws:s3:::fonts/*",
        "arn:aws:s3:::user-avatars/*",
        "arn:aws:s3:::backgrounds/*",
        "arn:aws:s3:::backups/*"
      ]
    }
  ]
}
