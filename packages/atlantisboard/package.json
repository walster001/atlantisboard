{
  "name": "atlantisboard",
  "version": "1.0.1",
  "description": "Atlantisboard - Self-hosted Open-source Kanban",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server/index.js",
  "module": "./dist/server/index.js",
  "style": "./public/index.css",
  "engines": {
    "bun": ">=1.3.5"
  },
  "exports": {
    ".": {
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./server": "./dist/server/index.js",
    "./worker": "./dist/workers/index.js",
    "./index.js": "./public/index.js",
    "./index.css": "./public/index.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "bin": {
    "atlantisboard": "install/bin/atlantisboard.js",
    "atlantisboard-setup": "install/bin/setup.sh",
    "atlantisboard-uninstall": "install/bin/uninstall.sh"
  },
  "files": [
    "dist",
    "public",
    "package.json",
    "bun.lock",
    ".env.example",
    "DEPLOYMENT.md",
    "README.md",
    "install",
    ".npmignore",
    "atlantisboard",
    "atlantisboard-setup",
    "atlantisboard-uninstall"
  ],
  "scripts": {
    "postinstall": "node install/postinstall.js",
    "start": "bun run dist/server/index.js",
    "start:worker": "bun run dist/workers/index.js"
  },
  "keywords": [
    "kanban",
    "atlantisboard",
    "trello",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walster001/atlantisboard.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.8.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "1.1.0",
    "@emoji-mart/data": "1.2.1",
