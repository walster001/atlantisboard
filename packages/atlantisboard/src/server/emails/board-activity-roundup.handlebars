<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100%;max-width:100%;">
  <tr>
    <td style="width:100%;max-width:100%;">
      <h2 style="margin:0 0 8px;font-size:22px;font-weight:600;color:{{defaultVal textColor "#38322d"}};">Weekly board activity</h2>
      <p style="margin:0 0 16px;font-size:15px;color:{{defaultVal textColor "#38322d"}};line-height:1.6;">
        Here is the complete activity log for <strong>{{boardName}}</strong> for {{periodLabel}}.
        Scroll within the log below to review every event from the week.
      </p>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
             style="width:100%;max-width:100%;margin:0 0 16px;background-color:{{defaultVal infoBoxBg "#f7f4ec"}};border-radius:8px;">
        <tr>
          <td style="padding:14px 16px;">
            <p style="margin:0;font-size:14px;color:{{defaultVal textColor "#38322d"}};font-weight:500;">
              {{activityCount}} activity {{#if multipleActivities}}events{{else}}event{{/if}}
            </p>
          </td>
        </tr>
      </table>

      {{{activitiesHtml}}}

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100%;margin:24px 0;">
        <tr>
          <td align="center"
              style="background-color:{{defaultVal buttonColor "#1a1a1a"}};border-radius:6px;">
            <a href="{{boardUrl}}"
               target="_blank"
               style="display:inline-block;padding:14px 32px;font-size:13px;font-weight:600;color:{{defaultVal buttonTextColor "#ffffff"}};text-decoration:none;text-transform:uppercase;letter-spacing:1.2px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
              Open board
            </a>
          </td>
        </tr>
      </table>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100%;max-width:100%;margin:16px 0 0;border-top:1px solid {{defaultVal separatorColor "#d9d4cb"}};padding-top:16px;">
        <tr>
          <td>
            <p style="margin:0;font-size:12px;color:{{defaultVal textColor "#38322d"}};opacity:0.5;line-height:1.5;">
              If the button doesn't work, copy and paste this URL into your browser:<br/>
              <a href="{{boardUrl}}" style="color:{{defaultVal linkColor "#4da6d8"}};word-break:break-all;">{{boardUrl}}</a>
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
