# Copy to scripts/prod-remote-deploy.env and fill in (file is gitignored).
# Used by scripts/prod-staging-remote-deploy.sh
#
# Quick prod deploy (no GitHub CLI): ./scripts/prod-staging-remote-deploy.sh --quick

# SSH target (required) — user@host or Host alias from ~/.ssh/config
PROD_REMOTE_SSH="user@your-prod-server"

# Existing install directory on the remote host
PROD_REMOTE_INSTALL_DIR="/opt/atlantisboard"

# Staging package directory on remote (upload + run setup from here)
PROD_REMOTE_PACKAGE_DIR="/tmp/atlantisboard-staging-package"

# Installer action: update rebuilds fullstack app image; repair only fixes missing files
PROD_REMOTE_INSTALL_ACTION="update"

# Git ref for CI + Staging workflows (branch name or commit SHA)
PROD_REMOTE_GIT_REF="main"

# GitHub repository (owner/name)
PROD_REMOTE_GITHUB_REPO="walster001/atlantisboard"

# Health check URL after deploy (defaults to remote APP_URL from .env, else localhost:PORT)
# PROD_REMOTE_HEALTH_URL="https://your-app.example/health"

# After a successful remote upgrade, unused Docker images and build cache are pruned
# (safe for running containers; prevents disk growth from repeated --build deploys).

# Optional SSH options (single string passed to ssh/scp/rsync)
# PROD_REMOTE_SSH_OPTS="-o StrictHostKeyChecking=accept-new"
